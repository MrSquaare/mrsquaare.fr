{
  "private": true,
  "name": "mrsquaare.fr",
  "type": "module",
  "scripts": {
    "root:check": "eslint . && prettier . --check",
    "root:check:fix": "eslint . --fix && prettier . --write",
    "dev": "turbo dev --continue",
    "build": "turbo build",
    "check": "turbo check --continue",
    "check:fix": "turbo check:fix --continue",
    "clean": "turbo clean --continue && del-cli node_modules/.cache/ .turbo/ **/.turbo/",
    "deps:update": "taze",
    "deps:upgrade": "taze -w",
    "version": "changeset version && pnpm install",
    "publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@mrsquaare-fr/eslint-config": "workspace:*",
    "@stylistic/eslint-plugin": "^5.10.0",
    "del-cli": "^7.0.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.4",
    "taze": "^19.14.1",
    "turbo": "^2.10.0",
    "typescript-eslint": "^8.62.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.9.0"
}
